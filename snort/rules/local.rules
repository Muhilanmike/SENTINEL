# Sentinel AI-IDS - Snort Local Rules
# These rules will be auto-updated by the ML engine

# SYN Flood Detection
alert tcp any any -> $HOME_NET any (msg:"SENTINEL SYN Flood Detected"; \
    flags:S; threshold:type both,track by_src,count 100,seconds 10; \
    priority:1; sid:1000001; rev:1;)

# Port Scan Detection
alert tcp any any -> $HOME_NET any (msg:"SENTINEL Port Scan Detected"; \
    flags:S; threshold:type both,track by_src,count 20,seconds 5; \
    priority:2; sid:1000002; rev:1;)

# SSH Brute Force Detection
alert tcp any any -> $HOME_NET 22 (msg:"SENTINEL SSH Brute Force Detected"; \
    threshold:type both,track by_src,count 5,seconds 60; \
    priority:2; sid:1000003; rev:1;)

# FTP Brute Force Detection
alert tcp any any -> $HOME_NET 21 (msg:"SENTINEL FTP Brute Force Detected"; \
    threshold:type both,track by_src,count 5,seconds 60; \
    priority:2; sid:1000004; rev:1;)

# DNS Amplification Attack
alert udp any any -> $HOME_NET 53 (msg:"SENTINEL DNS Amplification Detected"; \
    threshold:type both,track by_src,count 50,seconds 10; \
    priority:1; sid:1000005; rev:1;)

# HTTP Flood Detection
alert tcp any any -> $HOME_NET 80 (msg:"SENTINEL HTTP Flood Detected"; \
    threshold:type both,track by_src,count 200,seconds 10; \
    priority:2; sid:1000006; rev:1;)

# ICMP Flood Detection
alert icmp any any -> $HOME_NET any (msg:"SENTINEL ICMP Flood Detected"; \
    threshold:type both,track by_src,count 50,seconds 5; \
    priority:3; sid:1000007; rev:1;)

# RST Attack Detection
alert tcp any any -> $HOME_NET any (msg:"SENTINEL RST Attack Detected"; \
    flags:R; threshold:type both,track by_src,count 30,seconds 10; \
    priority:2; sid:1000008; rev:1;)

